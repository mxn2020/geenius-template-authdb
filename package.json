{
  "name": "geenius-template-authdb",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Geenius AuthDB Template — CRUD app starter with React + Convex + ConvexAuth + Tailwind CSS 4",
  "author": "Mehdi Nabhani <mehdi@geenius.dev>",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "dev:backend": "npx convex dev",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write '**/*' --ignore-unknown",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@convex-dev/auth": "^0.0.91",
    "@geenius-ui/react": "^0.1.4",
    "convex": "^1.32.0",
    "lucide-react": "^0.577.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "@tanstack/react-router": "^1.120.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}